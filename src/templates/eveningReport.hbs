<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Evening Attendance Report</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
      background: #f4f4f4;
      margin: 0;
      padding: 0;
    }
    .wrapper {
      max-width: 680px;
      margin: 40px auto;
      background: #ffffff;
      border: 1px solid #ddd;
      border-radius: 4px;
      overflow: hidden;
    }
    .header {
      background: #1a1a2e;
      padding: 24px 32px;
    }
    .header h1 {
      margin: 0;
      color: #ffffff;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0.3px;
    }
    .header p {
      margin: 4px 0 0 0;
      color: #aaa;
      font-size: 12px;
    }
    .body {
      padding: 32px;
    }
    .body p {
      margin: 0 0 16px 0;
      color: #444;
    }
    .all-clear {
      background: #f6fef9;
      border: 1px solid #b7e4c7;
      border-radius: 3px;
      padding: 20px 24px;
      margin: 16px 0 24px 0;
      color: #1a6e3a;
      font-size: 14px;
    }
    .all-clear strong {
      display: block;
      font-size: 15px;
      margin-bottom: 4px;
    }
    .summary-row {
      display: flex;
      gap: 16px;
      margin: 0 0 32px 0;
    }
    .summary-card {
      flex: 1;
      border: 1px solid #ddd;
      border-radius: 3px;
      padding: 16px 20px;
      text-align: center;
    }
    .summary-card .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #888;
      margin-bottom: 8px;
    }
    .summary-card .value {
      font-size: 32px;
      font-weight: 700;
      color: #1a1a2e;
      line-height: 1;
    }
    .section-title {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #888;
      border-bottom: 1px solid #eee;
      padding-bottom: 8px;
      margin: 0 0 16px 0;
    }
    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 32px 0;
      font-size: 13px;
    }
    .data-table th {
      text-align: left;
      padding: 8px 12px;
      background: #f5f5f5;
      color: #555;
      font-weight: 600;
      border-bottom: 1px solid #ddd;
    }
    .data-table td {
      padding: 10px 12px;
      border-bottom: 1px solid #eee;
      color: #333;
    }
    .data-table tr:last-child td {
      border-bottom: none;
    }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 2px;
      font-size: 11px;
      font-weight: 600;
    }
    .badge-overdue {
      background: #fdecea;
      color: #c0392b;
    }
    .badge-active {
      background: #fef9ec;
      color: #a07000;
    }
    .cta {
      display: inline-block;
      padding: 10px 20px;
      background: #1a1a2e;
      color: #ffffff;
      text-decoration: none;
      border-radius: 3px;
      font-size: 13px;
      font-weight: 500;
    }
    .footer {
      padding: 16px 32px;
      background: #f9f9f9;
      border-top: 1px solid #eee;
      font-size: 11px;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>Evening Attendance Report</h1>
      <p>{{companyName}} &mdash; {{reportDate}}</p>
    </div>

    <div class="body">
      <p>Good evening, <strong>{{managerName}}</strong>. Here is your end-of-day attendance summary.</p>

      {{#if showAllClear}}

      <div class="all-clear">
        <strong>All Clear</strong>
        All employees have completed their shifts and clocked out for the day.
      </div>

      {{else}}

      <div class="summary-row">
        <div class="summary-card">
          <div class="label">Missed Clock-Outs</div>
          <div class="value">{{missedCount}}</div>
        </div>
        <div class="summary-card">
          <div class="label">Still Clocked In</div>
          <div class="value">{{stillClockedInCount}}</div>
        </div>
      </div>

      {{#if missedClockOuts.length}}
      <div class="section-title">Missed Clock-Outs</div>
      <table class="data-table">
        <thead>
          <tr>
            <th>Employee</th>
            <th>Department</th>
            <th>Clock-In</th>
            <th>Expected Out</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {{#each missedClockOuts}}
          <tr>
            <td><strong>{{this.employeeName}}</strong></td>
            <td>{{this.department}}</td>
            <td>{{this.clockInTime}}</td>
            <td>{{this.expectedClockOut}}</td>
            <td><span class="badge badge-overdue">{{this.minutesOverdue}} min overdue</span></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}

      {{#if stillClockedIn.length}}
      <div class="section-title">Still Clocked In</div>
      <table class="data-table">
        <thead>
          <tr>
            <th>Employee</th>
            <th>Department</th>
            <th>Clock-In Time</th>
            <th>Hours</th>
            <th>Expected End</th>
          </tr>
        </thead>
        <tbody>
          {{#each stillClockedIn}}
          <tr>
            <td><strong>{{this.employeeName}}</strong></td>
            <td>{{this.department}}</td>
            <td>{{this.clockInTime}}</td>
            <td><span class="badge badge-active">{{this.hoursWorked}} hrs</span></td>
            <td>{{#if this.expectedClockOut}}{{this.expectedClockOut}}{{else}}&mdash;{{/if}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}

      {{/if}}

      <a href="{{appUrl}}/dashboard/company-panel/punch-logs" class="cta">View Full Report</a>
    </div>

    <div class="footer">
      This is an automated daily report from BizBuddy. Please do not reply to this email.
      &copy; {{currentYear}} BizBuddy LLC.
    </div>
  </div>
</body>
</html>
